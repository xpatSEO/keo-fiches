      "post_content": "<!-- wp:acf/fiche-pratique-hero {\"name\":\"acf/fiche-pratique-hero\",\"data\":{\"kb_fp_hero_badge\":\"GUIDE COMPLET\",\"_kb_fp_hero_badge\":\"field_fp_hero_badge\",\"kb_fp_hero_title\":\"Modèle de CGV 2026 - \\u003cspan\\u003eprêt, clair et conforme\\u003c/span\\u003e\",\"_kb_fp_hero_title\":\"field_fp_hero_title\",\"kb_fp_hero_cta_label\":\"Être accompagné dans la création\",\"_kb_fp_hero_cta_label\":\"field_fp_hero_cta_label\",\"kb_fp_hero_cta_url\":\"https://www.keobiz.fr/\",\"_kb_fp_hero_cta_url\":\"field_fp_hero_cta_url\"},\"mode\":\"edit\"} /-->\n\n<!-- wp:acf/fiche-pratique-retenir {\"name\":\"acf/fiche-pratique-retenir\",\"data\":{\"kb_fp_retenir_title\":\"Ce que vous devez retenir : Modèle de CGV 2026\",\"_kb_fp_retenir_title\":\"field_fp_retenir_title\",\"kb_fp_retenir_items_0_kb_fp_retenir_text\":\"\\u003cstrong\\u003eLes CGV, bien plus qu'une simple formalité : \\u003c/strong\\u003eLes Conditions Générales de Vente (CGV) constituent le contrat qui encadre chaque transaction entre votre entreprise et vos clients.\",\"_kb_fp_retenir_items_0_kb_fp_retenir_text\":\"field_fp_retenir_text\",\"kb_fp_retenir_items_1_kb_fp_retenir_text\":\"\\u003cstrong\\u003eVos cgv sont-elles obligatoires ? la distinction B2B / B2C : \\u003c/strong\\u003eL'obligation de communiquer vos CGV dépend directement de la nature de votre client.\",\"_kb_fp_retenir_items_1_kb_fp_retenir_text\":\"field_fp_retenir_text\",\"kb_fp_retenir_items_2_kb_fp_retenir_text\":\"\\u003cstrong\\u003eLa structure de vos CGV : les clauses indispensables à ne jamais oublier : \\u003c/strong\\u003eUn modèle de CGV sert de base, mais il doit impérativement être adapté à votre activité.\",\"_kb_fp_retenir_items_2_kb_fp_retenir_text\":\"field_fp_retenir_text\",\"kb_fp_retenir_items_3_kb_fp_retenir_text\":\"\\u003cstrong\\u003eComment rédiger et mettre en place vos conditions générales de vente : \\u003c/strong\\u003eStructurer ses CGV est une chose, les rendre opposables à vos clients en est une autre.\",\"_kb_fp_retenir_items_3_kb_fp_retenir_text\":\"field_fp_retenir_text\",\"kb_fp_retenir_items\":4,\"_kb_fp_retenir_items\":\"field_fp_retenir_items\"},\"mode\":\"edit\"} /-->\n\n<!-- wp:acf/fiche-pratique-parcours-etapes {\"name\":\"acf/fiche-pratique-parcours-etapes\",\"data\":{\"kb_fp_parcours_title\":\"L’essentiel \\u003cspan\\u003eà connaître\\u003c/span\\u003e\",\"_kb_fp_parcours_title\":\"field_fp_parcours_title\",\"kb_fp_parcours_steps_0_kb_fp_step_badge\":\"À savoir\",\"_kb_fp_parcours_steps_0_kb_fp_step_badge\":\"field_fp_step_badge\",\"kb_fp_parcours_steps_0_kb_fp_step_title\":\"Les CGV, bien plus qu'une \\u003cspan\\u003esimple formalité\\u003c/span\\u003e\",\"_kb_fp_parcours_steps_0_kb_fp_step_title\":\"field_fp_step_title\",\"kb_fp_parcours_steps_0_kb_fp_step_subtitle\":\"Les Conditions Générales de Vente (CGV) constituent le contrat qui encadre chaque transaction ent...\",\"_kb_fp_parcours_steps_0_kb_fp_step_subtitle\":\"field_fp_step_subtitle\",\"kb_fp_parcours_steps_0_kb_fp_step_title_url\":\"\",\"_kb_fp_parcours_steps_0_kb_fp_step_title_url\":\"field_fp_step_title_url\",\"kb_fp_parcours_steps_0_kb_fp_step_body\":\"\\u003cp\\u003eLes Conditions Générales de Vente (CGV) constituent le contrat qui encadre chaque transaction entre votre entreprise et vos clients. Elles définissent les droits et obligations de chacun, de la commande au paiement, en passant par la livraison et les éventuels litiges. On peut les voir comme le mode d'emploi de votre relation commerciale. Leur objectif est double : informer le client en toute transparence et sécuriser juridiquement votre activité.\\u003c/p\\u003e\\n\\u003cp\\u003eEn cas de désaccord ou de litige, ce sont elles qui serviront de référence. Des CGV claires et complètes permettent de réduire considérablement les risques d'impayés, de contestations sur la livraison ou de malentendus sur les garanties. Elles sont aussi un gage de crédibilité et de professionnalisme aux yeux de vos clients, qui savent précisément à quoi s'attendre en achetant vos produits ou services.\\u003c/p\\u003e\\n\\u003cp\\u003eIl est courant de les confondre avec les Conditions Générales d'Utilisation (CGU). La distinction est simple :\\u003c/p\\u003e\\n\\u003cul\\u003e\\n\\u003cli\\u003e\\u003cstrong\\u003eLes CGV\\u003c/strong\\u003e encadrent une relation \\u003cstrong\\u003ecommerciale\\u003c/strong\\u003e (la vente d'un bien ou d'une prestation).\\u003c/li\\u003e\\n\\u003cli\\u003e\\u003cstrong\\u003eLes CGU\\u003c/strong\\u003e régissent \\u003cstrong\\u003el'utilisation\\u003c/strong\\u003e d'un service, comme la simple navigation sur votre site internet, sans qu'il y ait forcément une transaction.\\u003c/li\\u003e\\n\\u003c/ul\\u003e\",\"_kb_fp_parcours_steps_0_kb_fp_step_body\":\"field_fp_step_body\",\"kb_fp_parcours_steps_0_kb_fp_step_resources\":0,\"_kb_fp_parcours_steps_0_kb_fp_step_resources\":\"field_fp_step_resources\",\"kb_fp_parcours_steps_0_kb_fp_step_promo_title\":\"La création d’une entreprise ça ne s’improvise pas, on s’en parle ?\",\"_kb_fp_parcours_steps_0_kb_fp_step_promo_title\":\"field_fp_step_promo_title\",\"kb_fp_parcours_steps_0_kb_fp_step_promo_text\":\"Statut juridique, immatriculation, obligations fiscales... Nous prenons en charge toutes vos démarches de A à Z.\",\"_kb_fp_parcours_steps_0_kb_fp_step_promo_text\":\"field_fp_step_promo_text\",\"kb_fp_parcours_steps_0_kb_fp_step_promo_btn\":\"Créer mon entreprise gratuitement\",\"_kb_fp_parcours_steps_0_kb_fp_step_promo_btn\":\"field_fp_step_promo_btn\",\"kb_fp_parcours_steps_0_kb_fp_step_promo_btn_url\":\"#\",\"_kb_fp_parcours_steps_0_kb_fp_step_promo_btn_url\":\"field_fp_step_promo_btn_url\",\"kb_fp_parcours_steps_0_kb_fp_step_promo_image\":32114,\"_kb_fp_parcours_steps_0_kb_fp_step_promo_image\":\"field_fp_step_promo_image\",\"kb_fp_parcours_steps_1_kb_fp_step_badge\":\"Obligations\",\"_kb_fp_parcours_steps_1_kb_fp_step_badge\":\"field_fp_step_badge\",\"kb_fp_parcours_steps_1_kb_fp_step_title\":\"Vos cgv sont-elles obligatoires ? la distinction B2B \\u003cspan\\u003e/ B2C\\u003c/span\\u003e\",\"_kb_fp_parcours_steps_1_kb_fp_step_title\":\"field_fp_step_title\",\"kb_fp_parcours_steps_1_kb_fp_step_subtitle\":\"Si votre client est un particulier (B2C)\",\"_kb_fp_parcours_steps_1_kb_fp_step_subtitle\":\"field_fp_step_subtitle\",\"kb_fp_parcours_steps_1_kb_fp_step_title_url\":\"\",\"_kb_fp_parcours_steps_1_kb_fp_step_title_url\":\"field_fp_step_title_url\",\"kb_fp_parcours_steps_1_kb_fp_step_body\":\"\\u003cp\\u003eL'obligation de communiquer vos CGV dépend directement de la nature de votre client. C'est un point de vigilance essentiel, car les règles diffèrent radicalement.\\u003c/p\\u003e\\n\\u003ch3\\u003eSi votre client est un particulier (B2C)\\u003c/h3\\u003e\\n\\u003cp\\u003eLa communication des CGV est une \\u003cstrong\\u003eobligation légale absolue\\u003c/strong\\u003e. En tant que professionnel, vous devez fournir ces informations à votre client consommateur avant la conclusion du contrat. C'est ce qu'on appelle l'obligation précontractuelle d'information. Le droit considère le consommateur comme la partie la plus vulnérable, qu'il faut protéger en lui donnant tous les éléments pour qu'il s'engage en connaissance de cause. La preuve que cette communication a bien eu lieu vous incombe. En cas de manquement, vous risquez une amende administrative pouvant aller jusqu'à 15 000 €.\\u003c/p\\u003e\\n\\u003ch3\\u003eSi votre client est un professionnel (B2B)\\u003c/h3\\u003e\\n\\u003cp\\u003eEntre professionnels, la situation est plus souple. Il n'est pas obligatoire de présenter spontanément vos CGV. Cependant, vous devez \\u003cstrong\\u003eobligatoirement les communiquer si un client professionnel en fait la demande\\u003c/strong\\u003e. Le refus est sanctionné par une amende pouvant atteindre 75 000 € pour une personne morale. On connaît la tentation de ne pas les fournir à un concurrent curieux, mais la loi est claire : s'il peut prouver une intention de commande, vous êtes tenu de les transmettre.\\u003c/p\\u003e\\n\\u003cblockquote\\u003e\\n\\u003cp\\u003e\\u003cstrong\\u003eLe cas du professionnel \\\"assimilé consommateur\\\"\\u003c/strong\\u003e\\u003cbr/\\u003eAttention, un client professionnel peut parfois bénéficier de la protection du droit de la consommation. C'est le cas s'il remplit trois conditions cumulatives : il emploie 5 salariés au maximum, le contrat est conclu hors de son champ d'activité principal, et la vente se fait à distance ou hors établissement (sur un salon, par exemple). Dans cette situation, ce sont les règles protectrices du B2C qui s'appliquent.\\u003c/p\\u003e\\n\\u003c/blockquote\\u003e\",\"_kb_fp_parcours_steps_1_kb_fp_step_body\":\"field_fp_step_body\",\"kb_fp_parcours_steps_1_kb_fp_step_resources\":0,\"_kb_fp_parcours_steps_1_kb_fp_step_resources\":\"field_fp_step_resources\",\"kb_fp_parcours_steps_1_kb_fp_step_promo_title\":\"La création d’une entreprise ça ne s’improvise pas, on s’en parle ?\",\"_kb_fp_parcours_steps_1_kb_fp_step_promo_title\":\"field_fp_step_promo_title\",\"kb_fp_parcours_steps_1_kb_fp_step_promo_text\":\"Statut juridique, immatriculation, obligations fiscales... Nous prenons en charge toutes vos démarches de A à Z.\",\"_kb_fp_parcours_steps_1_kb_fp_step_promo_text\":\"field_fp_step_promo_text\",\"kb_fp_parcours_steps_1_kb_fp_step_promo_btn\":\"Créer mon entreprise gratuitement\",\"_kb_fp_parcours_steps_1_kb_fp_step_promo_btn\":\"field_fp_step_promo_btn\",\"kb_fp_parcours_steps_1_kb_fp_step_promo_btn_url\":\"#\",\"_kb_fp_parcours_steps_1_kb_fp_step_promo_btn_url\":\"field_fp_step_promo_btn_url\",\"kb_fp_parcours_steps_1_kb_fp_step_promo_image\":26987,\"_kb_fp_parcours_steps_1_kb_fp_step_promo_image\":\"field_fp_step_promo_image\",\"kb_fp_parcours_steps_2_kb_fp_step_badge\":\"Les clauses\",\"_kb_fp_parcours_steps_2_kb_fp_step_badge\":\"field_fp_step_badge\",\"kb_fp_parcours_steps_2_kb_fp_step_title\":\"La structure de vos CGV : \\u003cspan\\u003eles clauses indispensables à ne jamais oublier\\u003c/span\\u003e\",\"_kb_fp_parcours_steps_2_kb_fp_step_title\":\"field_fp_step_title\",\"kb_fp_parcours_steps_2_kb_fp_step_subtitle\":\"Objet et champ d'application\",\"_kb_fp_parcours_steps_2_kb_fp_step_subtitle\":\"field_fp_step_subtitle\",\"kb_fp_parcours_steps_2_kb_fp_step_title_url\":\"\",\"_kb_fp_parcours_steps_2_kb_fp_step_title_url\":\"field_fp_step_title_url\",\"kb_fp_parcours_steps_2_kb_fp_step_body\":\"\\u003cp\\u003eUn modèle de CGV sert de base, mais il doit impérativement être adapté à votre activité. Voici les clauses incontournables qui doivent y figurer pour garantir leur validité et leur efficacité.\\u003c/p\\u003e\\n\\u003ch3\\u003eObjet et champ d'application\\u003c/h3\\u003e\\n\\u003cp\\u003eCette première clause sert à définir clairement ce que les CGV encadrent : la vente de quels produits ? La réalisation de quelles prestations de services ? S'appliquent-elles aux ventes en ligne, en magasin, ou les deux ? C'est le préambule qui pose le cadre général.\\u003c/p\\u003e\\n\\u003ch3\\u003ePrix et conditions de paiement\\u003c/h3\\u003e\\n\\u003cp\\u003eLa clarté sur le prix est non-négociable.\\u003c/p\\u003e\\n\\u003cul\\u003e\\n\\u003cli\\u003e\\u003cstrong\\u003ePrix :\\u003c/strong\\u003e Pour une clientèle de particuliers (B2C), les prix doivent toujours être indiqués Toutes Taxes Comprises (TTC). Pour les professionnels (B2B), il est d'usage d'afficher les prix Hors Taxes (HT), car la \\u003ca href=\\\"https://keobiz.fr/le-mag/tva\\\"\\u003egestion de la TVA\\u003c/a\\u003e est un élément central de leur comptabilité. Précisez la devise et la durée de validité de vos offres.\\u003c/li\\u003e\\n\\u003cli\\u003e\\u003cstrong\\u003eModalités de paiement :\\u003c/strong\\u003e Listez les moyens de paiement acceptés (carte bancaire, virement, etc.).\\u003c/li\\u003e\\n\\u003cli\\u003e\\u003cstrong\\u003eDélais de paiement :\\u003c/strong\\u003e Indiquez quand le paiement est exigible (à la commande, à la livraison, à 30 jours...).\\u003c/li\\u003e\\n\\u003cli\\u003e\\u003cstrong\\u003ePénalités de retard :\\u003c/strong\\u003e En B2B, il est obligatoire de mentionner le taux des pénalités de retard et le montant de l'indemnité forfaitaire pour frais de recouvrement (40 € minimum). En B2C, cette mention est possible mais moins systématique.\\u003c/li\\u003e\\n\\u003c/ul\\u003e\\n\\u003ch3\\u003eLivraison ou exécution de la prestation\\u003c/h3\\u003e\\n\\u003cp\\u003eCette section détaille tout le processus logistique.\\u003c/p\\u003e\\n\\u003cul\\u003e\\n\\u003cli\\u003e\\u003cstrong\\u003eDélais :\\u003c/strong\\u003e Fournissez une estimation du délai de livraison ou de la date d'exécution de la prestation.\\u003c/li\\u003e\\n\\u003cli\\u003e\\u003cstrong\\u003eCoûts et zones :\\u003c/strong\\u003e Précisez les frais de livraison et les zones géographiques desservies.\\u003c/li\\u003e\\n\\u003cli\\u003e\\u003cstrong\\u003eTransfert de propriété et des risques :\\u003c/strong\\u003e Indiquez à quel moment le bien devient la propriété du client et qui est responsable en cas de perte ou de dommage durant le transport.\\u003c/li\\u003e\\n\\u003cli\\u003e\\u003cstrong\\u003eProcédure de réception :\\u003c/strong\\u003e Expliquez ce que le client doit faire s'il reçoit un produit endommagé.\\u003c/li\\u003e\\n\\u003c/ul\\u003e\\n\\u003ch3\\u003eDroit de rétractation : la protection clé du consommateur\\u003c/h3\\u003e\\n\\u003cp\\u003eCette clause est \\u003cstrong\\u003ecruciale et obligatoire en B2C\\u003c/strong\\u003e pour les contrats conclus à distance ou hors établissement.\\u003c/p\\u003e\\n\\u003cul\\u003e\\n\\u003cli\\u003e\\u003cstrong\\u003eDélai :\\u003c/strong\\u003e Le consommateur dispose d'un délai légal de 14 jours pour changer d'avis, sans avoir à se justifier.\\u003c/li\\u003e\\n\\u003cli\\u003e\\u003cstrong\\u003eModalités :\\u003c/strong\\u003e Expliquez clairement comment exercer ce droit (formulaire à renvoyer, contact du service client...).\\u003c/li\\u003e\\n\\u003cli\\u003e\\u003cstrong\\u003eRemboursement :\\u003c/strong\\u003e Précisez les conditions de retour du produit et le délai de remboursement.\\u003c/li\\u003e\\n\\u003cli\\u003e\\u003cstrong\\u003eExclusions :\\u003c/strong\\u003e Listez les cas où le droit de rétractation ne s'applique pas (biens personnalisés, produits périssables, etc.).\\u003c/li\\u003e\\n\\u003c/ul\\u003e\\n\\u003ch3\\u003eGaranties légales\\u003c/h3\\u003e\\n\\u003cp\\u003eVous devez informer vos clients de l'existence des garanties légales qui s'imposent à tout vendeur professionnel.\\u003c/p\\u003e\\n\\u003cul\\u003e\\n\\u003cli\\u003e\\u003cstrong\\u003eGarantie légale de conformité :\\u003c/strong\\u003e Elle protège le consommateur contre les défauts de conformité du produit (bien qui ne correspond pas à la description, impropre à l'usage attendu...).\\u003c/li\\u003e\\n\\u003cli\\u003e\\u003cstrong\\u003eGarantie contre les vices cachés :\\u003c/strong\\u003e Elle couvre les défauts non apparents au moment de l'achat qui rendent le produit inutilisable ou diminuent fortement son usage.\\u003c/li\\u003e\\n\\u003c/ul\\u003e\\n\\u003cp\\u003eSi vous proposez une garantie commerciale supplémentaire, ses conditions (durée, étendue, exclusions) doivent être détaillées ici.\\u003c/p\\u003e\\n\\u003ch3\\u003eResponsabilité et cas de force majeure\\u003c/h3\\u003e\\n\\u003cp\\u003eCette clause vise à délimiter votre responsabilité. Vous pouvez prévoir des cas où votre responsabilité ne pourra être engagée, comme une mauvaise utilisation du produit par le client. Mentionnez également les cas de force majeure (événements imprévisibles, irrésistibles et extérieurs) qui suspendent vos obligations contractuelles.\\u003c/p\\u003e\\n\\u003cdiv class=\\\"note\\\"\\u003e\\n\\u003ch4\\u003eClause de réserve de propriété\\u003c/h4\\u003e\\n\\u003cp\\u003eParticulièrement utile en B2B, cette clause stipule que vous restez propriétaire des biens vendus jusqu'au paiement intégral du prix par le client. En cas de non-paiement, elle vous permet de revendiquer et récupérer votre marchandise plus facilement.\\u003c/p\\u003e\\n\\u003c/div\\u003e\\n\\u003ch3\\u003eProtection des données personnelles (RGPD)\\u003c/h3\\u003e\\n\\u003cp\\u003eDepuis l'entrée en vigueur du RGPD, cette mention est indispensable. Vous devez informer vos clients sur :\\u003c/p\\u003e\\n\\u003cul\\u003e\\n\\u003cli\\u003eLes données personnelles que vous collectez (nom, adresse, email...).\\u003c/li\\u003e\\n\\u003cli\\u003eLa finalité de cette collecte (gestion de la commande, livraison, marketing...).\\u003c/li\\u003e\\n\\u003cli\\u003eLa durée de conservation des données.\\u003c/li\\u003e\\n\\u003cli\\u003eLes droits des personnes concernées (accès, rectification, suppression...).\\u003c/li\\u003e\\n\\u003c/ul\\u003e\\n\\u003ch3\\u003eRèglement des litiges et droit applicable\\u003c/h3\\u003e\\n\\u003cp\\u003ePrécisez le droit applicable au contrat (généralement le droit français) et la juridiction compétente en cas de litige. Pour les clients consommateurs, vous devez également mentionner la possibilité de recourir à un médiateur de la consommation, en indiquant ses coordonnées.\\u003c/p\\u003e\",\"_kb_fp_parcours_steps_2_kb_fp_step_body\":\"field_fp_step_body\",\"kb_fp_parcours_steps_2_kb_fp_step_resources\":0,\"_kb_fp_parcours_steps_2_kb_fp_step_resources\":\"field_fp_step_resources\",\"kb_fp_parcours_steps_2_kb_fp_step_promo_title\":\"La création d’une entreprise ça ne s’improvise pas, on s’en parle ?\",\"_kb_fp_parcours_steps_2_kb_fp_step_promo_title\":\"field_fp_step_promo_title\",\"kb_fp_parcours_steps_2_kb_fp_step_promo_text\":\"Statut juridique, immatriculation, obligations fiscales... Nous prenons en charge toutes vos démarches de A à Z.\",\"_kb_fp_parcours_steps_2_kb_fp_step_promo_text\":\"field_fp_step_promo_text\",\"kb_fp_parcours_steps_2_kb_fp_step_promo_btn\":\"Créer mon entreprise gratuitement\",\"_kb_fp_parcours_steps_2_kb_fp_step_promo_btn\":\"field_fp_step_promo_btn\",\"kb_fp_parcours_steps_2_kb_fp_step_promo_btn_url\":\"#\",\"_kb_fp_parcours_steps_2_kb_fp_step_promo_btn_url\":\"field_fp_step_promo_btn_url\",\"kb_fp_parcours_steps_2_kb_fp_step_promo_image\":32114,\"_kb_fp_parcours_steps_2_kb_fp_step_promo_image\":\"field_fp_step_promo_image\",\"kb_fp_parcours_steps_3_kb_fp_step_badge\":\"Méthode\",\"_kb_fp_parcours_steps_3_kb_fp_step_badge\":\"field_fp_step_badge\",\"kb_fp_parcours_steps_3_kb_fp_step_title\":\"Comment rédiger et mettre en place vos conditions générales de \\u003cspan\\u003evente ?\\u003c/span\\u003e\",\"_kb_fp_parcours_steps_3_kb_fp_step_title\":\"field_fp_step_title\",\"kb_fp_parcours_steps_3_kb_fp_step_subtitle\":\"Structurer ses CGV est une chose, les rendre opposables à vos clients en est une autre.\",\"_kb_fp_parcours_steps_3_kb_fp_step_subtitle\":\"field_fp_step_subtitle\",\"kb_fp_parcours_steps_3_kb_fp_step_title_url\":\"\",\"_kb_fp_parcours_steps_3_kb_fp_step_title_url\":\"field_fp_step_title_url\",\"kb_fp_parcours_steps_3_kb_fp_step_body\":\"\\u003cp\\u003eStructurer ses CGV est une chose, les rendre opposables à vos clients en est une autre. La méthode est cruciale pour que le document ait une réelle valeur juridique.\\u003c/p\\u003e\\n\\u003cp\\u003eD'abord, partez d'un modèle fiable mais personnalisez-le scrupuleusement. Chaque activité a ses spécificités (type de produits, logistique, clientèle...). Un simple copier-coller des CGV d'un concurrent est une erreur dangereuse qui peut vous exposer à des sanctions et laisser votre entreprise sans protection adéquate.\\u003c/p\\u003e\\n\\u003cp\\u003eEnsuite, assurez-vous de leur accessibilité et de leur acceptation. Pour un site e-commerce, elles doivent être facilement accessibles (un lien dans le pied de page, par exemple). Surtout, le client doit activement les accepter avant de valider sa commande, généralement via une case à cocher avec une phrase du type \\\"Je reconnais avoir lu et accepté les Conditions Générales de Vente\\\". Cette action formalise son consentement et rend le contrat applicable. Pour une prestation de service, faites-les figurer au dos de vos devis et factures et mentionnez sur le recto que la signature du devis vaut acceptation des CGV.\\u003c/p\\u003e\\n\\u003cdiv class=\\\"advice\\\"\\u003e\\n\\u003ch4\\u003eFaites valider vos CGV par un professionnel\\u003c/h4\\u003e\\n\\u003cp\\u003eLa rédaction de clauses juridiques engage votre responsabilité. Pour dormir sur vos deux oreilles, il est fortement recommandé de faire relire et valider vos CGV par un professionnel (avocat ou juriste). Un \\u003ca href=\\\"https://keobiz.fr/le-mag/expert-comptable-en-ligne-ce-quil-faut-savoir-sur-le-metier\\\"\\u003eexpert-comptable en ligne\\u003c/a\\u003e peut également vous orienter sur les aspects financiers et fiscaux à intégrer, assurant une cohérence parfaite avec votre gestion.\\u003c/p\\u003e\\n\\u003c/div\\u003e\",\"_kb_fp_parcours_steps_3_kb_fp_step_body\":\"field_fp_step_body\",\"kb_fp_parcours_steps_3_kb_fp_step_resources\":0,\"_kb_fp_parcours_steps_3_kb_fp_step_resources\":\"field_fp_step_resources\",\"kb_fp_parcours_steps_3_kb_fp_step_promo_title\":\"La création d’une entreprise ça ne s’improvise pas, on s’en parle ?\",\"_kb_fp_parcours_steps_3_kb_fp_step_promo_title\":\"field_fp_step_promo_title\",\"kb_fp_parcours_steps_3_kb_fp_step_promo_text\":\"Statut juridique, immatriculation, obligations fiscales... Nous prenons en charge toutes vos démarches de A à Z.\",\"_kb_fp_parcours_steps_3_kb_fp_step_promo_text\":\"field_fp_step_promo_text\",\"kb_fp_parcours_steps_3_kb_fp_step_promo_btn\":\"Créer mon entreprise gratuitement\",\"_kb_fp_parcours_steps_3_kb_fp_step_promo_btn\":\"field_fp_step_promo_btn\",\"kb_fp_parcours_steps_3_kb_fp_step_promo_btn_url\":\"#\",\"_kb_fp_parcours_steps_3_kb_fp_step_promo_btn_url\":\"field_fp_step_promo_btn_url\",\"kb_fp_parcours_steps_3_kb_fp_step_promo_image\":26987,\"_kb_fp_parcours_steps_3_kb_fp_step_promo_image\":\"field_fp_step_promo_image\",\"kb_fp_parcours_steps_4_kb_fp_step_badge\":\"Vigilance\",\"_kb_fp_parcours_steps_4_kb_fp_step_badge\":\"field_fp_step_badge\",\"kb_fp_parcours_steps_4_kb_fp_step_title\":\"Les erreurs fréquentes à éviter pour des \\u003cspan\\u003eCGV conformes\\u003c/span\\u003e\",\"_kb_fp_parcours_steps_4_kb_fp_step_title\":\"field_fp_step_title\",\"kb_fp_parcours_steps_4_kb_fp_step_subtitle\":\"Certains pièges sont courants et peuvent invalider vos CGV ou affaiblir votre protection.\",\"_kb_fp_parcours_steps_4_kb_fp_step_subtitle\":\"field_fp_step_subtitle\",\"kb_fp_parcours_steps_4_kb_fp_step_title_url\":\"\",\"_kb_fp_parcours_steps_4_kb_fp_step_title_url\":\"field_fp_step_title_url\",\"kb_fp_parcours_steps_4_kb_fp_step_body\":\"\\u003cp\\u003eCertains pièges sont courants et peuvent invalider vos CGV ou affaiblir votre protection. On les a tous vus, et il est simple de les éviter.\\u003c/p\\u003e\\n\\u003col\\u003e\\n\\u003cli\\u003e\\u003cp\\u003e\\u003cstrong\\u003eCopier-coller sans adapter :\\u003c/strong\\u003e C'est l'erreur la plus fréquente. Les CGV d'un autre site ne correspondront jamais parfaitement à votre activité, à vos processus de livraison ou à votre politique de retour.\\u003c/p\\u003e\\u003c/li\\u003e\\n\\u003cli\\u003e\\u003cp\\u003e\\u003cstrong\\u003eUtiliser un langage trop complexe :\\u003c/strong\\u003e Vos CGV doivent être lisibles et compréhensibles, surtout en B2C. Le jargon juridique excessif peut être considéré comme une clause abusive.\\u003c/p\\u003e\\u003c/li\\u003e\\n\\u003cli\\u003e\\u003cp\\u003e\\u003cstrong\\u003eOublier des mentions obligatoires :\\u003c/strong\\u003e L'absence d'une information clé, comme les modalités du droit de rétractation, peut entraîner des sanctions et l'annulation de certaines clauses.\\u003c/p\\u003e\\u003c/li\\u003e\\n\\u003cli\\u003e\\u003cp\\u003e\\u003cstrong\\u003eNe pas les mettre à jour :\\u003c/strong\\u003e La législation évolue. Des CGV rédigées il y a cinq ans ne sont probablement plus conformes. Pensez à les réviser régulièrement.\\u003c/p\\u003e\\u003c/li\\u003e\\n\\u003cli\\u003e\\u003cp\\u003e\\u003cstrong\\u003eMélanger les règles B2B et B2C :\\u003c/strong\\u003e Appliquer des conditions B2B (comme l'absence de droit de rétractation) à un client particulier est illégal. Il est souvent plus simple de prévoir deux documents distincts.\\u003c/p\\u003e\\u003c/li\\u003e\\n\\u003c/ol\\u003e\\n\\u003cp\\u003eLes Conditions Générales de Vente ne sont pas qu'un document légal à produire pour être en règle. Elles sont le reflet de votre professionnalisme et la pierre angulaire d'une relation commerciale transparente et saine. En y consacrant le temps nécessaire, vous ne faites pas que vous conformer à la loi : vous investissez dans la confiance de vos clients et dans la pérennité de votre entreprise. C'est un effort initial qui sécurise d'innombrables transactions futures.\\u003c/p\\u003e\",\"_kb_fp_parcours_steps_4_kb_fp_step_body\":\"field_fp_step_body\",\"kb_fp_parcours_steps_4_kb_fp_step_resources\":0,\"_kb_fp_parcours_steps_4_kb_fp_step_resources\":\"field_fp_step_resources\",\"kb_fp_parcours_steps_4_kb_fp_step_promo_title\":\"La création d’une entreprise ça ne s’improvise pas, on s’en parle ?\",\"_kb_fp_parcours_steps_4_kb_fp_step_promo_title\":\"field_fp_step_promo_title\",\"kb_fp_parcours_steps_4_kb_fp_step_promo_text\":\"Statut juridique, immatriculation, obligations fiscales... Nous prenons en charge toutes vos démarches de A à Z.\",\"_kb_fp_parcours_steps_4_kb_fp_step_promo_text\":\"field_fp_step_promo_text\",\"kb_fp_parcours_steps_4_kb_fp_step_promo_btn\":\"Créer mon entreprise gratuitement\",\"_kb_fp_parcours_steps_4_kb_fp_step_promo_btn\":\"field_fp_step_promo_btn\",\"kb_fp_parcours_steps_4_kb_fp_step_promo_btn_url\":\"#\",\"_kb_fp_parcours_steps_4_kb_fp_step_promo_btn_url\":\"field_fp_step_promo_btn_url\",\"kb_fp_parcours_steps_4_kb_fp_step_promo_image\":32114,\"_kb_fp_parcours_steps_4_kb_fp_step_promo_image\":\"field_fp_step_promo_image\",\"kb_fp_parcours_steps\":5,\"_kb_fp_parcours_steps\":\"field_fp_parcours_steps\"},\"mode\":\"edit\"} /-->\n\n<!-- wp:acf/fiche-pratique-auteur {\"name\":\"acf/fiche-pratique-auteur\",\"data\":{\"kb_fp_auteur_authors_override\":23773,\"_kb_fp_auteur_authors_override\":\"field_fp_auteur_authors_override\"},\"mode\":\"edit\"} /-->\n\n<!-- wp:acf/fiche-pratique-cta-rendez-vous {\"name\":\"acf/fiche-pratique-cta-rendez-vous\",\"data\":{\"kb_fp_cta_rdv_text\":\"La création d’une entreprise ça ne s’improvise \\u003cbr\\u003epas, on s’en parle ?\",\"_kb_fp_cta_rdv_text\":\"field_fp_cta_rdv_text\",\"kb_fp_cta_rdv_btn\":\"Prendre un rendez-vous\",\"_kb_fp_cta_rdv_btn\":\"field_fp_cta_rdv_btn\",\"kb_fp_cta_rdv_url\":\"#\",\"_kb_fp_cta_rdv_url\":\"field_fp_cta_rdv_url\"},\"mode\":\"edit\"} /-->\n\n<!-- wp:acf/fiche-pratique-rubriques-nav {\"name\":\"acf/fiche-pratique-rubriques-nav\",\"data\":{\"kb_fp_rubnav_title\":\"Un projet d’entreprise en particulier ? \\u003cbr\\u003eRetrouvez toutes nos autres \\u003cspan\\u003efiches pratiques :\\u003c/span\\u003e\",\"_kb_fp_rubnav_title\":\"field_fp_rubnav_title\",\"kb_fp_rubnav_intro\":\"\",\"_kb_fp_rubnav_intro\":\"field_fp_rubnav_intro\",\"kb_fp_rubnav_items_0_kb_fp_rubnav_item_url\":\"#\",\"_kb_fp_rubnav_items_0_kb_fp_rubnav_item_url\":\"field_fp_rubnav_item_url\",\"kb_fp_rubnav_items_0_kb_fp_rubnav_item_label\":\"Fiches Artisan du BTP\",\"_kb_fp_rubnav_items_0_kb_fp_rubnav_item_label\":\"field_fp_rubnav_item_label\",\"kb_fp_rubnav_items_0_kb_fp_rubnav_item_icon\":30850,\"_kb_fp_rubnav_items_0_kb_fp_rubnav_item_icon\":\"field_fp_rubnav_item_icon\",\"kb_fp_rubnav_items_1_kb_fp_rubnav_item_url\":\"#\",\"_kb_fp_rubnav_items_1_kb_fp_rubnav_item_url\":\"field_fp_rubnav_item_url\",\"kb_fp_rubnav_items_1_kb_fp_rubnav_item_label\":\"Fiches Consultant indépendant\",\"_kb_fp_rubnav_items_1_kb_fp_rubnav_item_label\":\"field_fp_rubnav_item_label\",\"kb_fp_rubnav_items_1_kb_fp_rubnav_item_icon\":30847,\"_kb_fp_rubnav_items_1_kb_fp_rubnav_item_icon\":\"field_fp_rubnav_